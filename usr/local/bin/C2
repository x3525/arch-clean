#!/bin/bash

brightness () {
    brightnessctl set "$2"%"$1"
}

lock () {
    dunstctl set-paused true

    i3lock -n -c 000000 -p default -e -f -k &

    wait

    dunstctl set-paused false
}

menu () {
    rofi -no-lazy-grab -show "$1" -modes "$1" -theme "$1"
}

notify () {
    case $1 in
        gammastep)
            summary=$2
            urgency=low

            case $2 in
                daytime)
                    icon=daytime-sunrise-symbolic
                    ;;
                night)
                    icon=daytime-sunset-symbolic
                    ;;
            esac
            ;;
        volume)
            pamixer -"$2" "$3" --allow-boost --set-limit=150

            summary=$(pamixer --get-volume)
            urgency=low

            if pamixer --get-mute | grep -q true
            then
                icon=volume-level-none
            else
                icon=volume-level-high
            fi

            hint=(--hint=int:value:"$summary")
            ;;
    esac

    hint+=(--hint=string:x-dunst-stack-tag:"$1")

    notify-send "$summary" "${body:-}" --urgency="$urgency" --icon="$icon" "${hint[@]}"
}

execute () {
    for desktop in "$1"/*
    do
        for pid in $(pgrep -f -- "$(dex -p Name "$desktop")")
        do
            if ps eww -p "$pid" | grep DISPLAY="$DISPLAY" | grep -q _="$(command -v dex)"
            then
                kill "$pid"

                while pgrep -p "$pid"
                do
                    sleep 1
                done
            fi
        done
    done

    dex -a -s "$1"
}

$1 "${@:2}"
