#!/bin/bash

brightness() {
    brightnessctl set "$2"%"$1"
}

lock() {
    dunstctl set-paused true

    i3lock -n -c 000000 -p default -e -f -k &

    wait

    dunstctl set-paused false
}

menu() {
    rofi -no-lazy-grab -show "$1" -modes "$1" -theme "$1"
}

notify() {
    case $1 in
        volume)
            pamixer -"$2" "$3" --allow-boost --set-limit=150

            if pamixer --get-mute | grep -q true
            then
                ICON=volume-level-none
            else
                ICON=volume-level-high
            fi

            notify-send -h string:x-dunst-stack-tag:"$1" -u low -i "$ICON" "" -h int:value:"$(pamixer --get-volume)"
            ;;
    esac
}

execute() {
    for d in "$1"/*
    do
        for pid in $(pgrep -f -- "$(dex -p Name "$d")")
        do
            if ps eww -p "$pid" | grep DISPLAY="$DISPLAY" | grep -q _="$(command -v dex)"
            then
                kill "$pid"

                while pgrep -p "$pid"
                do
                    sleep 1
                done
            fi
        done
    done

    dex -a -s "$1"
}

$1 "${@:2}"
