{
    "cSpell.blockCheckingWhenAverageChunkSizeGreaterThan": 1000000,
    "cSpell.blockCheckingWhenLineLengthGreaterThan": 1000000,
    "cSpell.blockCheckingWhenTextChunkSizeGreaterThan": 1000000,
    "cSpell.language": "en,tr",
    "cSpell.maxDuplicateProblems": 1000000,
    "cSpell.maxNumberOfProblems": 1000000,
    "cSpell.minWordLength": 3,
    "editor.detectIndentation": false,
    "editor.fontFamily": "JetBrains Mono",
    "editor.quickSuggestions": {"other": "off", "comments": "off", "strings": "off"},
    "editor.renderWhitespace": "all",
    "editor.wordBasedSuggestions": "off",
    "explorer.compactFolders": false,
    "files.trimTrailingWhitespace": true,
    "markdownlint.config": {"MD045": false, "MD046": false},
    "telemetry.telemetryLevel": "off",
    "terminal.external.linuxExec": "alacritty",
    "terminal.integrated.defaultLocation": "editor",
    "terminal.integrated.enableFileLinks": "off",
    "terminal.integrated.enableMultiLinePasteWarning": "always",
    "terminal.integrated.fontFamily": "MesloLGMDZ Nerd Font Mono",
    "terminal.integrated.mouseWheelScrollSensitivity": 5,
    "terminal.integrated.rightClickBehavior": "selectWord",
    "terminal.integrated.shellIntegration.decorationsEnabled": "overviewRuler",
    "workbench.editor.enablePreview": false,
    "workbench.editor.focusRecentEditorAfterClose": false,
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "workbench.list.openMode": "doubleClick",
    "workbench.startupEditor": "none"
