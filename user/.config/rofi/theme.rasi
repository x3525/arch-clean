* {
    background-color: transparent;
    text-color: White;
}

element {
    children: [ element-icon, element-text ];
    padding: 20px;
    spacing: 20px;
}

element selected {
    background-color: DarkSlateGray;
}

element-icon {
    size: 48px;
}

element-text {
    vertical-align: 0.5;
}

inputbar {
    enabled: false;
}

listview {
    spacing: 0px;
}

mainbox {
    background-color: Black;
}

window {
    fullscreen: true;
}
