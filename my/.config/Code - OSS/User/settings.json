{
    "cSpell.blockCheckingWhenAverageChunkSizeGreaterThan": 1000000,
    "cSpell.blockCheckingWhenLineLengthGreaterThan": 1000000,
    "cSpell.blockCheckingWhenTextChunkSizeGreaterThan": 1000000,
    "cSpell.caseSensitive": false,
    "cSpell.checkLimit": 1000,
    "cSpell.diagnosticLevel": "Information",
    "cSpell.language": "en,tr",
    "cSpell.maxDuplicateProblems": 1000000,
    "cSpell.maxNumberOfProblems": 1000000,
    "cSpell.minWordLength": 3,
    "cSpell.showStatus": true,
    "editor.detectIndentation": false,
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontSize": 14,
    "editor.quickSuggestions": {"comments": "off", "other": "off", "strings": "off"},
    "editor.renderWhitespace": "all",
    "editor.tabSize": 4,
    "editor.unicodeHighlight.allowedLocales": {"tr": true},
    "editor.wordBasedSuggestions": "off",
    "explorer.compactFolders": false,
    "files.autoSave": "off",
    "files.trimTrailingWhitespace": true,
    "markdownlint.config": {"MD045": false, "MD046": false},
    "redhat.telemetry.enabled": false,
    "window.customTitleBarVisibility": "never",
    "workbench.activityBar.location": "top",
    "workbench.editor.enablePreview": false,
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "workbench.list.openMode": "doubleClick",
    "workbench.startupEditor": "none"
