zle_highlight=(
    # Any text within the command line not affected by any other highlighting.
    default:none
    # The area of the command line matched by the search string or pattern.
    isearch:standout
    # The currently selected text.
    region:none
    # Individual characters that have no direct printable representation.
    special:none
    # Suffixes that will be removed if the completion ends at that point.
    suffix:none
    # The characters that were inserted.
    paste:none
)
